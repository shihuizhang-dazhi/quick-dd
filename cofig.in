[mimo]
# 小米 MiMo AI 配置（用于联网搜索找域名）
api_key = 
base_url = https://api.xiaomimimo.com/v1
model = mimo-v2.5-pro

[zhipu]
# 智谱 AI 配置（用于过滤域名，便宜）
api_key = 
base_url = https://open.bigmodel.cn/api/paas/v4
model = glm-4-flash

[fofa]
# FOFA API
# 注册获取：https://fofa.info
email = your_email@example.com
key = your_fofa_api_key

[mxnzp]
# mxnzp.com ICP 备案查询
# https://www.mxnzp.com/api/beian/search
app_id = 
app_secret =

